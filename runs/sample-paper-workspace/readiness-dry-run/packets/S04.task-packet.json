{
  "agent_type": "verifier",
  "allowed_actions": [
    "read_material_bundle",
    "draft_candidate_artifact",
    "return_evidence"
  ],
  "allowed_read_paths": [
    "examples/materials/phase10_s03_contribution_options.yaml",
    "examples/materials/evidence_inventory.v1.yaml",
    "examples/materials/claim_boundary_map.v2.yaml",
    "examples/materials/reader_spine.v1.yaml",
    "examples/materials/terminology_register.v1.yaml",
    "examples/materials/reference_sidecar.v1.yaml"
  ],
  "allowed_tools": [
    "none"
  ],
  "allowed_write_paths": [
    "runs/sample-paper-workspace/readiness-dry-run/candidate-artifacts/S04.candidate-placeholder.json"
  ],
  "completion_forbidden": true,
  "coverage_ledgers_required": [
    "claim_queue",
    "claim_coverage_ledger",
    "atomic_claim_register",
    "evidence_locator_coverage",
    "unsupported_claim_backflow_register",
    "downstream_use_permission_matrix"
  ],
  "evidence_anchors": [
    "examples/materials/phase10_s03_contribution_options.yaml",
    "examples/materials/evidence_inventory.v1.yaml",
    "examples/materials/claim_boundary_map.v2.yaml",
    "examples/materials/reader_spine.v1.yaml",
    "examples/materials/terminology_register.v1.yaml",
    "examples/materials/reference_sidecar.v1.yaml"
  ],
  "expected_material_type": "S04ClaimAdmissibility",
  "expected_output_schema": "ppg-material/v0.1",
  "expected_payload_schema": "ppg-s04-claim-admissibility/v0.1",
  "failure_report_format": "MissingMaterialReport with run-owned candidate path, consumed material ids, validator evidence, and no source-repository writes",
  "forbidden_routes": [
    "mark_graph_complete",
    "dispatch_subagents",
    "write_outside_allowed_write_paths",
    "change_owner_intent"
  ],
  "ingestion_target": "runs/sample-paper-workspace/readiness-dry-run/candidate-artifacts/S04.candidate-placeholder.json",
  "input_materials": [
    "phase10_s03_contribution_options",
    "evidence_inventory_v1",
    "claim_boundary_map_v2",
    "reader_spine_v1",
    "terminology_register_v1",
    "reference_sidecar_v1"
  ],
  "internal_execution_protocol": {
    "coverage_ledger_required": true,
    "downstream_handoff_required": true,
    "no_final_prose": true,
    "no_new_claims_unless_stage_allows": false,
    "no_silent_omission": true,
    "required_passes": [
      {
        "objective": "Extract claim candidates from S03 options, motivation, result artifacts, citation/evidence materials, and writing-intended controls.",
        "pass_id": "claim_bearing_unit_extraction"
      },
      {
        "objective": "Split compound claims into method, novelty, result, safety, generalization, deployment, limitation, and background atomic units.",
        "pass_id": "atomic_claim_decomposition"
      },
      {
        "objective": "Bind every atomic claim to source/result/citation/artifact locators or mark missing evidence and visibility gaps.",
        "pass_id": "evidence_anchor_lookup"
      },
      {
        "objective": "Classify each claim as strong, moderate, weak, background_only, unsupported, or forbidden.",
        "pass_id": "support_strength_classification"
      },
      {
        "objective": "Derive admitted wording, allowed verbs/modifiers, required qualifiers, forbidden wording, required caveats, and downstream permissions.",
        "pass_id": "wording_boundary_derivation"
      },
      {
        "objective": "State what every result artifact supports and does not support, including allowed metrics and forbidden interpretations.",
        "pass_id": "result_package_boundary_pass"
      },
      {
        "objective": "Route admitted capsules to S05/S07/S10/S12/S13 and route missing evidence or semantic shifts to S01/S03/S00.",
        "pass_id": "downstream_handoff_backflow_pass"
      },
      {
        "objective": "Verify no claim lacks support strength, evidence anchor, allowed wording, forbidden wording, result boundary, coverage ledger row, or downstream decision.",
        "pass_id": "independent_verifier_pass"
      }
    ],
    "unresolved_register_required": true,
    "work_queue_required": true
  },
  "mandatory_controls": {
    "allowed_and_forbidden_wording_required": true,
    "claim_boundary": "claim_boundary_map_v2",
    "claim_status_values": [
      "admitted",
      "weakened",
      "rejected",
      "backflowed",
      "owner_gated"
    ],
    "completion_boundary": "claim_admissibility_only_no_final_prose_no_graph_or_manuscript_completion",
    "contribution_options": "phase10_s03_contribution_options",
    "evidence_inventory": "evidence_inventory_v1",
    "forbidden_interpretations": [
      "Do not treat citation presence as empirical support.",
      "Do not admit unsupported or forbidden claims.",
      "Do not strengthen moderate or weak claims into proof language.",
      "Do not convert raw S03 options into S05/S07/S10 writing without S04 capsules.",
      "Do not infer deployment, public-road, closed-loop, or generalization claims from bounded result artifacts."
    ],
    "nature_overlay_packet_clauses": [
      "nature_overlay_ref:nature_expert_writing",
      "nature_stage_binding:S04",
      "nature_overlay_role:primary"
    ],
    "nature_overlay_ref": "runtime/stage_overlay_registry.json#nature_expert_writing",
    "nature_overlay_stage_binding": "S04",
    "no_claim_without_evidence": true,
    "no_evidence_without_boundary": true,
    "no_final_prose": true,
    "reader_spine": "reader_spine_v1",
    "reference_sidecar": "reference_sidecar_v1",
    "s03_raw_options_not_writing_ready": true,
    "support_strength_values": [
      "strong",
      "moderate",
      "weak",
      "background_only",
      "unsupported",
      "forbidden"
    ],
    "terminology_register": "terminology_register_v1"
  },
  "mission": "Generate S04 claim capsules by admitting, weakening, rejecting, or backflowing every claim-bearing unit against evidence anchors, support strength, allowed wording, forbidden wording, and result-package boundaries.",
  "no_recursive_orchestration": true,
  "output_artifact_path": "runs/sample-paper-workspace/readiness-dry-run/candidate-artifacts/S04.candidate-placeholder.json",
  "output_contract": {
    "material_type": "S04ClaimAdmissibility",
    "payload_schema": "ppg-s04-claim-admissibility/v0.1",
    "required_modules": [
      "completion_boundary",
      "claim_queue",
      "claim_unit_decomposition",
      "atomic_claim_register",
      "claim_capsules",
      "support_strength_map",
      "evidence_anchor_map",
      "allowed_wording_map",
      "forbidden_wording_map",
      "result_package_boundary_matrix",
      "claim_transformation_log",
      "data_availability_plan",
      "downstream_handoffs",
      "claim_coverage_ledger",
      "unsupported_claim_backflow_register",
      "evidence_locator_coverage",
      "downstream_use_permission_matrix",
      "unresolved_backflow_register",
      "candidate_return"
    ]
  },
  "owner_gate_required": false,
  "packet_id": "phase10_s04_evidence_claim_admissibility_packet_v1.phase10_run",
  "return_format": {
    "candidate_artifact": "required",
    "evidence": "required",
    "missing_material_report": "required_if_blocked",
    "remaining_risks": "required"
  },
  "schema_version": "ppg-task-packet/v0.1",
  "stage_contract_ref": "examples/stage-contracts/S04.stage-contract.json",
  "stage_id": "S04",
  "status": "planned",
  "stop_condition": "S04 candidate artifact written to the run-owned path only; return evidence without claiming graph, manuscript, or submission completion.",
  "target_material": "phase10_s04_claim_admissibility",
  "task_kind": "evidence_claim_admissibility",
  "validators": [
    "validate_packet:phase10_stage_binding",
    "validate_material:S04ClaimAdmissibility",
    "content_validator:S04:claim_admissibility_payload",
    "claim_capsule_required:S04",
    "allowed_forbidden_wording_required:S04",
    "result_boundary_required:S04",
    "stage_overlay:nature_expert_writing:S04"
  ],
  "worker_boot_clause": "completion_forbidden; no_recursive_orchestration; allowed_write_paths; MissingMaterialReport required when materials are missing; return candidate/evidence only; S04 admits/weakens/rejects claim units and must not produce final_prose, manuscript_ready, submission_ready, or graph_complete fields."
}
