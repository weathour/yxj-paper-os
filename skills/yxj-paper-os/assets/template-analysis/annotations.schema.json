{
  "$defs": {
    "annotation": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "resolution": {
                "const": "accepted"
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "source_sha256"
                ]
              },
              {
                "required": [
                  "object_fingerprint"
                ]
              }
            ]
          }
        }
      ],
      "properties": {
        "doc_id": {
          "minLength": 1,
          "type": "string"
        },
        "encoding": {
          "type": "object"
        },
        "object_fingerprint": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "object_id": {
          "minLength": 1,
          "type": "string"
        },
        "origin": {
          "enum": [
            "artifact-observed",
            "owner-stated",
            "model-derived",
            "model-proposed"
          ]
        },
        "panels": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "encodings": {
                "items": {
                  "$ref": "#/$defs/encoding"
                },
                "type": "array",
                "uniqueItems": true
              },
              "order": {
                "minimum": 1,
                "type": "integer"
              },
              "panel_id": {
                "minLength": 1,
                "type": "string"
              },
              "role": {
                "$ref": "#/$defs/role"
              }
            },
            "required": [
              "panel_id",
              "order",
              "role",
              "encodings"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "resolution": {
          "enum": [
            "accepted",
            "candidate",
            "rejected"
          ]
        },
        "role": {
          "additionalProperties": false,
          "properties": {
            "primary": {
              "$ref": "#/$defs/role"
            },
            "secondary": {
              "items": {
                "$ref": "#/$defs/role"
              },
              "type": "array",
              "uniqueItems": true
            }
          },
          "required": [
            "primary"
          ],
          "type": "object"
        },
        "source_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "doc_id",
        "object_id",
        "origin",
        "resolution",
        "role"
      ],
      "type": "object"
    },
    "encoding": {
      "enum": [
        "line",
        "bar",
        "scatter",
        "box",
        "violin",
        "heatmap",
        "map",
        "network",
        "image",
        "diagram",
        "flowchart",
        "table",
        "error-bar",
        "uncertainty-band",
        "raw-points",
        "other"
      ]
    },
    "role": {
      "enum": [
        "overview",
        "architecture",
        "workflow",
        "formulation",
        "method-detail",
        "main-result",
        "comparison",
        "ablation",
        "sensitivity",
        "robustness",
        "efficiency",
        "interpretability",
        "failure-analysis",
        "case-study",
        "limitation",
        "uncertainty",
        "data",
        "other"
      ]
    }
  },
  "$id": "https://yxj-paper-os.local/schema/template-annotations-1.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "annotations": {
      "items": {
        "$ref": "#/$defs/annotation"
      },
      "type": "array"
    },
    "schema": {
      "const": "template-annotations/1.0"
    }
  },
  "required": [
    "schema",
    "annotations"
  ],
  "title": "YXJ template object annotations",
  "type": "object"
}
