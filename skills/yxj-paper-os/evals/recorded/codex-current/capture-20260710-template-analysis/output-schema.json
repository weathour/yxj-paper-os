{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "responses": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "question": {
            "additionalProperties": false,
            "properties": {
              "count": {
                "minimum": 0,
                "type": "integer"
              },
              "target": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "count",
              "target"
            ],
            "type": "object"
          },
          "readiness_updates": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "blocker": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "next_action": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "output_pointer": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "readiness": {
                  "enum": [
                    "writer-ready",
                    "partial",
                    "blocked",
                    "deferred"
                  ],
                  "type": "string"
                },
                "scope_id": {
                  "type": "string"
                }
              },
              "required": [
                "blocker",
                "next_action",
                "output_pointer",
                "readiness",
                "scope_id"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "scenario_id": {
            "enum": [
              "B01",
              "B02",
              "B03",
              "B04",
              "B05",
              "B06",
              "B07",
              "B08",
              "B09",
              "B10",
              "B11",
              "B12",
              "B13",
              "B14",
              "B15",
              "B16",
              "B17",
              "B18",
              "B19",
              "B20"
            ]
          },
          "selected_actions": {
            "items": {
              "enum": [
                "ASK_OWNER",
                "COMPILE_SCOPED_HANDOFF",
                "DEPENDENCY_RECHECK",
                "DERIVE",
                "INITIALIZE_WORKSPACE",
                "INSPECT",
                "KEEP_CLAIM_INACTIVE",
                "PROPOSE",
                "RECONCILE",
                "RECORD_OBSERVATION"
              ]
            },
            "type": "array"
          },
          "side_effects": {
            "items": {
              "enum": [
                "external_execution",
                "full_scan",
                "pdf_pseudo_parse",
                "subagents",
                "template_analysis",
                "template_intake"
              ]
            },
            "type": "array"
          },
          "target_dimensions": {
            "items": {
              "pattern": "^D(?:0[0-9]|1[0-9])$",
              "type": "string"
            },
            "type": "array"
          },
          "target_scopes": {
            "items": {
              "pattern": "^SCOPE-",
              "type": "string"
            },
            "type": "array"
          },
          "updates": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "analysis_mode": {
                  "enum": [
                    "case_set",
                    "exploratory",
                    "distributional",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "candidate_action": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "decision_pointer": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "grounding": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "locator": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "operation": {
                  "type": "string"
                },
                "origin": {
                  "enum": [
                    "artifact-observed",
                    "owner-stated",
                    "model-derived",
                    "model-proposed",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "reason": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "record_id": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "record_kind": {
                  "type": "string"
                },
                "resolution": {
                  "enum": [
                    "confirmed",
                    "unresolved",
                    "candidate",
                    "accepted",
                    "rejected",
                    "stale",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "status": {
                  "enum": [
                    "active",
                    "inactive",
                    "candidate",
                    "blocked",
                    "ready",
                    "partial",
                    "unsupported",
                    "stale",
                    "confirmed",
                    "deferred",
                    "rejected",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "support": {
                  "enum": [
                    "evidence-supported",
                    "evidence-partial",
                    "evidence-unsupported",
                    "not_applicable",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "target_kind": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "analysis_mode",
                "candidate_action",
                "decision_pointer",
                "grounding",
                "locator",
                "operation",
                "origin",
                "reason",
                "record_id",
                "record_kind",
                "resolution",
                "status",
                "support",
                "target_kind"
              ],
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "question",
          "readiness_updates",
          "scenario_id",
          "selected_actions",
          "side_effects",
          "target_dimensions",
          "target_scopes",
          "updates"
        ],
        "type": "object"
      },
      "maxItems": 20,
      "minItems": 20,
      "type": "array"
    }
  },
  "required": [
    "responses"
  ],
  "type": "object"
}
