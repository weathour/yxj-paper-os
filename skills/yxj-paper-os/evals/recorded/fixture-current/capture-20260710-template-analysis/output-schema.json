{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "responses": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "question": {
            "additionalProperties": false,
            "properties": {
              "count": {
                "minimum": 0,
                "type": "integer"
              },
              "target": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "count",
              "target"
            ],
            "type": "object"
          },
          "readiness_updates": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "blocker": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "next_action": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "output_pointer": {
                  "pattern": "^[0-9]{2}_[A-Z0-9_]+\\.md#[^\\s#]+$",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "readiness": {
                  "enum": [
                    "writer-ready",
                    "partial",
                    "blocked",
                    "deferred"
                  ],
                  "type": "string"
                },
                "scope_id": {
                  "pattern": "^SCOPE-[A-Z0-9][A-Z0-9-]*$",
                  "type": "string"
                }
              },
              "required": [
                "blocker",
                "next_action",
                "output_pointer",
                "readiness",
                "scope_id"
              ],
              "type": "object"
            },
            "type": "array",
            "uniqueItems": true
          },
          "scenario_id": {
            "enum": [
              "B01",
              "B02",
              "B03",
              "B04",
              "B05",
              "B06",
              "B07",
              "B08",
              "B09",
              "B10",
              "B11",
              "B12",
              "B13",
              "B14",
              "B15"
            ]
          },
          "selected_actions": {
            "items": {
              "enum": [
                "ASK_OWNER",
                "DERIVE",
                "INSPECT",
                "PROJECT",
                "VALIDATE"
              ]
            },
            "type": "array",
            "uniqueItems": true
          },
          "side_effects": {
            "items": {
              "enum": [
                "external_execution",
                "full_scan",
                "pdf_pseudo_parse",
                "subagents",
                "template_analysis",
                "template_intake"
              ]
            },
            "type": "array",
            "uniqueItems": true
          },
          "target_dimensions": {
            "items": {
              "pattern": "^D(?:0[0-9]|1[0-9])$",
              "type": "string"
            },
            "type": "array",
            "uniqueItems": true
          },
          "target_scopes": {
            "items": {
              "pattern": "^SCOPE-",
              "type": "string"
            },
            "type": "array",
            "uniqueItems": true
          },
          "updates": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "access_state": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "analysis_mode": {
                  "enum": [
                    "case_set",
                    "exploratory",
                    "distributional",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "candidate_action": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "decision_pointer": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "denominator": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "design_only_state": {
                  "enum": [
                    "design_only",
                    "not_applicable",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "design_payload": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "effective_conclusion": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "epistemic_label": {
                  "enum": [
                    "artifact-observed",
                    "owner-stated",
                    "model-derived",
                    "model-proposed",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "gate_category": {
                  "enum": [
                    "scientific_commitment",
                    "argument_spine",
                    "material_local_tradeoff",
                    "deliberate_divergence",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "grounding": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "uniqueItems": true
                },
                "linked_records": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "uniqueItems": true
                },
                "locator": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "missingness": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "operation": {
                  "enum": [
                    "create",
                    "revise"
                  ],
                  "type": "string"
                },
                "origin": {
                  "enum": [
                    "artifact-observed",
                    "owner-stated",
                    "model-derived",
                    "model-proposed",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "partition": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "promotion_pointer": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "reason": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "record_id": {
                  "pattern": "\\S",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "record_kind": {
                  "enum": [
                    "claim",
                    "decision",
                    "diagnostic",
                    "frame",
                    "material",
                    "paragraph",
                    "semantic_dossier",
                    "surface",
                    "template_analysis",
                    "template_rule",
                    "template_source",
                    "visual"
                  ],
                  "type": "string"
                },
                "resolution": {
                  "enum": [
                    "confirmed",
                    "unresolved",
                    "candidate",
                    "accepted",
                    "rejected",
                    "stale",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "role": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "schema_version": {
                  "enum": [
                    "0.2",
                    "0.3",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "status": {
                  "enum": [
                    "active",
                    "inactive",
                    "candidate",
                    "blocked",
                    "ready",
                    "partial",
                    "unsupported",
                    "stale",
                    "confirmed",
                    "deferred",
                    "rejected",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "support": {
                  "enum": [
                    "evidence-supported",
                    "evidence-partial",
                    "evidence-unsupported",
                    "not_applicable",
                    null
                  ],
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "target_kind": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "access_state",
                "analysis_mode",
                "candidate_action",
                "decision_pointer",
                "denominator",
                "design_only_state",
                "design_payload",
                "effective_conclusion",
                "epistemic_label",
                "gate_category",
                "grounding",
                "linked_records",
                "locator",
                "missingness",
                "operation",
                "origin",
                "partition",
                "promotion_pointer",
                "reason",
                "record_id",
                "record_kind",
                "resolution",
                "role",
                "schema_version",
                "status",
                "support",
                "target_kind"
              ],
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "question",
          "readiness_updates",
          "scenario_id",
          "selected_actions",
          "side_effects",
          "target_dimensions",
          "target_scopes",
          "updates"
        ],
        "type": "object"
      },
      "maxItems": 15,
      "minItems": 15,
      "type": "array"
    }
  },
  "required": [
    "responses"
  ],
  "type": "object"
}
