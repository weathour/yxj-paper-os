    "S10 receives paragraph-depth obligations",
    "S12 checks promise/payoff",
    "S13 can attack unresolved reader questions"
  ],
  "failure_severity_policy": {
    "BLOCKING": "missing reader question route for admitted core claim",
    "MAJOR": "paragraph-depth obligations too weak for target profile",
    "MINOR": "local trace, label, or wording defect that does not alter authority",
    "WATCH": "potential reviewer risk tracked without forced full rerun"
  },
  "nearest_responsible_stage_policy": "S05 for reader-spine/depth defects",
  "affected_downstream_nodes": [
    "S06",
    "S07",
    "S08",
    "S09B",
    "S10",
    "S12",
    "S13",
    "RenderedManuscriptAuditGate"
  ],
  "anti_over_strictness_boundary": "MINOR and WATCH findings enter local revision or risk ledger; they do not force full downstream rerun by default."
}
