{
  "schema_version": "ppg-stage-quality-contract/v0.1",
  "stage_id": "S05",
  "active_profile_source": "S02 template profile plus S03/S04 contribution and claim boundaries",
  "must_read_materials": [
    {
      "material_ref": "S04_claim_admissibility",
      "read_mode": "full",
      "required_extractions": [
        "admitted_claims",
        "rejected_claims",
        "citation_burden"
      ]
    },
    {
      "material_ref": "S03_contribution_options",
      "read_mode": "targeted",
      "required_extractions": [
        "reviewer_attack_map",
        "contribution_route"
      ]
    },
    {
      "material_ref": "S02_research_dossier",
      "read_mode": "targeted",
      "required_extractions": [
        "section_length_bands",
        "rhetorical_move_profile"
      ]
    }
  ],
  "required_extractions": [
    "reader_questions",
    "section_jobs",
    "paragraph_depth_obligations",
    "promise_payoff_map",
    "reviewer_question_map"
  ],
  "producer_return_obligations": [
    "reader spine",
    "paragraph-depth ledger",
    "section job map",
    "S06/S07/S08/S10 handoffs",
    "obligation coverage ledger",
    "missing material report when blocked"
  ],
  "audit_verifier_obligations": {
    "inherits_all_producer_inputs": true,
    "checks": [
      "every reader question has section job",
      "paragraph depth matches active profile",
      "front-half promises have payoff sections",
      "reviewer attacks become obligations",
      "downstream usefulness",
      "nearest responsible stage routing"
