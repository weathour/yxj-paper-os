{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.yxj/ppg-graph.schema.json",
  "title": "Paper Production Graph",
  "type": "object",
  "required": ["schema_version", "graph_id", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "ppg-graph/v0.1" },
    "graph_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "node_type", "label", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node_type": {
          "enum": [
            "owner_intent",
            "material",
            "transform_task",
            "agent_run",
            "validator",
            "validation_report",
            "manuscript_artifact",
            "review_finding",
            "backflow_task"
          ]
        },
        "label": { "type": "string", "minLength": 1 },
        "status": {
          "enum": [
            "planned",
            "candidate",
            "validated",
            "committed",
            "stale",
            "rejected",
            "blocked",
            "owner_gated"
          ]
        },
        "version": { "type": "string" },
        "layer": { "type": "integer", "minimum": 0 },
        "artifact_path": { "type": "string" },
        "summary": { "type": "string" },
        "payload_ref": { "type": "string" },
        "validators": { "type": "array", "items": { "type": "string" } },
        "stale_reason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target", "edge_type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "edge_type": {
          "enum": [
            "consumes",
            "constrains",
            "produces",
            "validates",
            "reports",
            "invalidates",
            "repairs",
            "supersedes",
            "references"
          ]
        },
        "dependency_strength": { "enum": ["hard", "soft", "provenance"] },
        "label": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
