{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-material-payloads.schema.json",
  "title": "PPG Material Payload Semantic Vocabulary",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "EvidenceInventory": {
      "type": "object",
      "required": [
        "evidence_packages"
      ],
      "properties": {
        "evidence_packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "claim_strength"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "claim_strength": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "ClaimBoundaryMap": {
      "type": "object",
      "properties": {
        "allowed_claims": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "strength"
            ],
            "properties": {
              "strength": {
                "type": "string",
                "enum": [
                  "bounded",
                  "bounded-method-evidence",
                  "descriptive",
                  "evidence_supported",
                  "limited",
                  "qualified"
                ]
              },
              "id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "forbidden_claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_wording": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_terms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ReaderSpine": {
      "type": "object",
      "required": [
        "questions"
      ],
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "TerminologyRegister": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
