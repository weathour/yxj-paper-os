{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.yxj/ppg-transform-task.schema.json",
  "title": "PPG Transform Task",
  "description": "A bounded transform over material versions. Transform tasks may produce candidate or committed material nodes only after validator-backed commit protocol.",
  "type": "object",
  "required": ["schema_version", "task_id", "task_kind", "status", "consumes", "produces"],
  "properties": {
    "schema_version": { "const": "ppg-transform-task/v0.1" },
    "task_id": { "type": "string", "minLength": 1 },
    "task_kind": {
      "enum": ["material_derivation", "repair", "writing_packet", "review", "validation", "export", "other"]
    },
    "status": {
      "enum": ["planned", "candidate", "validated", "committed", "stale", "rejected", "blocked", "owner_gated"]
    },
    "stage_family": { "type": "string" },
    "consumes": { "type": "array", "items": { "type": "string" } },
    "produces": { "type": "array", "items": { "type": "string" } },
    "validators": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" }
  },
  "additionalProperties": true
}
