{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/ppg-pilot-stage-run.schema.json",
  "title": "PPG PilotStageRun",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "stage_id",
    "contract_ref",
    "status",
    "coverage_kind",
    "exercise_level",
    "consumed_materials",
    "produced_artifacts",
    "validator_evidence",
    "source_projection_boundary",
    "completion_claim"
  ],
  "properties": {
    "schema_version": {"const": "ppg-pilot-stage-run/v0.1"},
    "stage_id": {"type": "string", "pattern": "^(S(0[0-8]|09A|09B|1[0-6])|G0[12])$"},
    "contract_ref": {"type": "string", "pattern": "^examples/stage-contracts/(S(0[0-8]|09A|09B|1[0-6])|G0[12])\\.stage-contract\\.json$"},
    "status": {"enum": ["validated", "owner_gated", "blocked"]},
    "coverage_kind": {"enum": ["source_projected", "fixture_generated", "script_checked", "owner_gated_deferred", "not_applicable_with_reason"]},
    "exercise_level": {"enum": ["full_stage_exercised", "contract_only", "deferred_with_gate", "not_applicable"]},
    "consumed_materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["material_id", "kind", "ref"],
        "properties": {
          "material_id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "producer_stage_id": {"type": "string", "pattern": "^(S(0[0-8]|09A|09B|1[0-6])|G0[12])$"},
          "ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "produced_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type", "artifact_path"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "artifact_type": {"type": "string", "minLength": 1},
          "artifact_path": {"type": "string", "minLength": 1}
        }
      }
    },
    "validator_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["validator", "status", "evidence"],
        "properties": {
          "validator": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "blocked", "warning"]},
          "evidence": {"type": "string", "minLength": 1}
        }
      }
    },
    "source_projection_boundary": {
      "type": "object",
      "required": [
        "read_only_source",
        "writes_to_source_allowed",
        "runtime_output_under_source",
        "source_status_unchanged",
        "selected_source_fingerprints_unchanged",
        "projection_scope"
      ],
      "properties": {
        "read_only_source": {"const": true},
        "writes_to_source_allowed": {"const": false},
        "runtime_output_under_source": {"const": false},
        "source_status_unchanged": {"const": true},
        "selected_source_fingerprints_unchanged": {"const": true},
        "projection_scope": {"type": "string", "minLength": 1}
      }
    },
    "completion_claim": {"type": "string", "minLength": 1}
  }
}
