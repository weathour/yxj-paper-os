{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ppg-lifecycle-contract.schema.json",
  "title": "Paper OS feedback lifecycle contract",
  "type": "object",
  "required": [
    "schema_version",
    "lifecycle_id",
    "status",
    "standalone_contract",
    "feedback_packages",
    "attributions",
    "repair_packets",
    "retrospectives",
    "stage_improvements"
  ],
  "properties": {
    "schema_version": {"const": "ppg-lifecycle-contract/v0.1"},
    "lifecycle_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["planned", "candidate", "validated"]},
    "standalone_contract": {
      "type": "object",
      "required": ["omx_dependency", "host_local_dependency", "authority_source"],
      "properties": {
        "omx_dependency": {"const": false},
        "host_local_dependency": {"const": false},
        "authority_source": {"const": "paper_os"},
        "optional_adapters": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "feedback_packages": {"type": "array", "minItems": 1},
    "attributions": {"type": "array", "minItems": 1},
    "repair_packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "repair_packet_id",
          "status",
          "attribution_id",
          "target_material",
          "repair_action",
          "allowed_write_paths",
          "validators",
          "completion_forbidden",
          "no_recursive_orchestration"
        ],
        "anyOf": [
          {"required": ["task_packet_ref"]},
          {"required": ["backflow_task_ref"]}
        ],
        "properties": {
          "schema_version": {"const": "ppg-repair-task-packet/v0.1"},
          "task_packet_ref": {
            "type": "string",
            "pattern": "^examples/packets/[^\\\\\\s]+\\.(ya?ml|json)$"
          },
          "backflow_task_ref": {
            "type": "string",
            "pattern": "^examples/backflow_tasks/[^\\\\\\s]+\\.(ya?ml|json)$"
          },
          "completion_forbidden": {"const": true},
          "no_recursive_orchestration": {"const": true},
          "allowed_write_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "validators": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": true
      }
    },
    "retrospectives": {"type": "array", "minItems": 1},
    "stage_improvements": {"type": "array", "minItems": 1}
  },
  "additionalProperties": true
}
