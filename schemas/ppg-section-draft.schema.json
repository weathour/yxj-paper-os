{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-section-draft.schema.json",
  "title": "PPG SectionDraft Markdown Front Matter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "draft_id",
    "status",
    "section_id",
    "packet_id",
    "source_materials",
    "evidence_anchors",
    "graph_completion_claimed",
    "recursive_dispatch_requested"
  ],
  "properties": {
    "schema_version": {"const": "ppg-section-draft/v0.1"},
    "draft_id": {"type": "string", "minLength": 1},
    "status": {"const": "candidate"},
    "section_id": {"type": "string", "minLength": 1},
    "packet_id": {"type": "string", "minLength": 1},
    "source_materials": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "evidence_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "graph_completion_claimed": {"const": false},
    "recursive_dispatch_requested": {"const": false}
  }
}
