{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ppg-rendered-manuscript-audit-gate.schema.json",
  "title": "PPG RenderedManuscriptAuditGate",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "gate_id",
    "target_binding",
    "input_refs",
    "rendered_inputs",
    "quality_checks",
    "severity_summary",
    "decision",
    "handoff_boundary",
    "feedback_route"
  ],
  "properties": {
    "schema_version": {"const": "ppg-rendered-manuscript-audit-gate/v0.1"},
    "gate_id": {"const": "RenderedManuscriptAuditGate"},
    "target_binding": {
      "type": "object",
      "required": ["delivery_target_kind", "source", "compiled_target"],
      "properties": {
        "delivery_target_kind": {"type": "string", "minLength": 1},
        "active_target_ref": {"type": ["string", "null"]},
        "source": {"type": "string", "minLength": 1},
        "compiled_target": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "input_refs": {
      "type": "object",
      "required": ["s16_export_handoff_package_ref", "output_pdf_ref", "rendered_text_ref", "file_hash_manifest_ref"],
      "properties": {
        "s16_export_handoff_package_ref": {"type": "string", "minLength": 1},
        "output_pdf_ref": {"type": "string", "minLength": 1},
        "rendered_text_ref": {"type": "string", "minLength": 1},
        "file_hash_manifest_ref": {"type": "string", "minLength": 1},
        "source_writeback_evidence_ref": {"type": ["string", "null"]},
        "post_writeback_validation_ref": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "rendered_inputs": {
      "type": "object",
      "required": ["pdf_sha256", "rendered_text_sha256", "template_only_detected", "internal_lexicon_detected", "unresolved_risk_leakage_detected"],
      "properties": {
        "pdf_sha256": {"type": "string", "minLength": 1},
        "rendered_text_sha256": {"type": "string", "minLength": 1},
        "template_only_detected": {"type": "boolean"},
        "internal_lexicon_detected": {"type": "boolean"},
        "unresolved_risk_leakage_detected": {"type": "boolean"},
        "rendered_text_excerpt": {"type": "string"}
      },
      "additionalProperties": true
    },
    "quality_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_id", "status", "severity", "evidence_ref", "nearest_responsible_stage"],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "fail", "risk"]},
          "severity": {"enum": ["BLOCKING", "MAJOR", "MINOR", "WATCH"]},
          "evidence_ref": {"type": "string", "minLength": 1},
          "nearest_responsible_stage": {"type": "string", "minLength": 1},
          "finding_route": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "severity_summary": {
      "type": "object",
      "required": ["BLOCKING", "MAJOR", "MINOR", "WATCH"],
      "properties": {
        "BLOCKING": {"type": "integer", "minimum": 0},
        "MAJOR": {"type": "integer", "minimum": 0},
        "MINOR": {"type": "integer", "minimum": 0},
        "WATCH": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "decision": {
      "type": "object",
      "required": ["status", "rationale", "owner_gate_required", "submission_ready_claimed"],
      "properties": {
        "status": {"enum": ["pass", "blocked"]},
        "rationale": {"type": "string", "minLength": 1},
        "owner_gate_required": {"type": "boolean"},
        "submission_ready_claimed": {"const": false}
      },
      "additionalProperties": true
    },
    "handoff_boundary": {
      "type": "object",
      "required": ["s16_export_is_input_not_quality_gate", "submission_owner_gated", "publication_claim_forbidden"],
      "properties": {
        "s16_export_is_input_not_quality_gate": {"const": true},
        "submission_owner_gated": {"const": true},
        "publication_claim_forbidden": {"const": true}
      },
      "additionalProperties": true
    },
    "feedback_route": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
