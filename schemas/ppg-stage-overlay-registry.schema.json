{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-stage-overlay-registry.schema.json",
  "title": "PPG Stage Overlay Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_ref",
    "packet_clause_transport",
    "overlays",
    "completion_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "ppg-stage-overlay-registry/v0.1"
    },
    "registry_ref": {
      "const": "runtime/stage_registry.json"
    },
    "description": {
      "type": "string"
    },
    "packet_clause_transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_level_packet_fields_forbidden", "mandatory_controls_keys", "validator_prefix"],
      "properties": {
        "top_level_packet_fields_forbidden": {"const": true},
        "mandatory_controls_keys": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "validator_prefix": {"type": "string", "pattern": "^stage_overlay:[^:]+:$"}
      }
    },
    "overlays": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/overlay"}
    },
    "completion_boundary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "stage_id": {
      "type": "string",
      "pattern": "^(S(0[0-8]|09A|09B|1[0-6])|G0[12])$"
    },
    "string_list": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overlay_id",
        "profile_kind",
        "authority_model",
        "required_stage_bindings",
        "primary_stage_bindings",
        "stage_bindings"
      ],
      "properties": {
        "overlay_id": {"type": "string", "minLength": 1},
        "profile_kind": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "authority_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stage_local_only",
            "no_new_department",
            "controller_owned_completion",
            "worker_completion_forbidden",
            "no_recursive_orchestration",
            "overlay_dispatch_allowed",
            "route_kind"
          ],
          "properties": {
            "stage_local_only": {"const": true},
            "no_new_department": {"const": true},
            "controller_owned_completion": {"const": true},
            "worker_completion_forbidden": {"const": true},
            "no_recursive_orchestration": {"const": true},
            "overlay_dispatch_allowed": {"const": false},
            "route_kind": {"const": "stage_local_overlay"}
          }
        },
        "required_stage_bindings": {
          "type": "array",
          "items": {"$ref": "#/$defs/stage_id"},
          "minItems": 1
        },
        "primary_stage_bindings": {
          "type": "array",
          "items": {"$ref": "#/$defs/stage_id"},
          "minItems": 1
        },
        "support_stage_bindings": {
          "type": "array",
          "items": {"$ref": "#/$defs/stage_id"}
        },
        "stage_bindings": {
          "type": "array",
          "items": {"$ref": "#/$defs/stage_binding"},
          "minItems": 1
        }
      }
    },
    "stage_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "binding_strength",
        "overlay_role",
        "input_controls",
        "output_materials",
        "packet_clauses",
        "validator_checks",
        "backflow_targets",
        "prohibited_routes"
      ],
      "properties": {
        "stage_id": {"$ref": "#/$defs/stage_id"},
        "binding_strength": {"enum": ["primary", "support", "light", "governance", "derivative"]},
        "overlay_role": {"type": "string", "minLength": 1},
        "input_controls": {"$ref": "#/$defs/string_list"},
        "output_materials": {"$ref": "#/$defs/string_list"},
        "packet_clauses": {"$ref": "#/$defs/string_list"},
        "validator_checks": {"$ref": "#/$defs/string_list"},
        "backflow_targets": {
          "type": "array",
          "items": {"$ref": "#/$defs/stage_id"},
          "minItems": 1
        },
        "prohibited_routes": {"$ref": "#/$defs/string_list"},
        "notes": {"type": "string"}
      }
    }
  }
}
