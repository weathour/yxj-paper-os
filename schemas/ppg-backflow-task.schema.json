{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-backflow-task.schema.json",
  "title": "PPG BackflowTask",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "backflow_id", "finding_id", "status", "target", "action"],
  "properties": {
    "schema_version": {"const": "ppg-backflow-task/v0.1"},
    "backflow_id": {"type": "string", "minLength": 1},
    "finding_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["planned", "candidate", "validated", "committed", "stale", "rejected", "blocked", "owner_gated"]},
    "target": {"type": "string", "minLength": 1},
    "action": {"type": "string", "minLength": 1},
    "expected_output": {"type": "string"}
  }
}
