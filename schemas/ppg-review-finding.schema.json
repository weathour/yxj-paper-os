{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-review-finding.schema.json",
  "title": "PPG ReviewFinding",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "finding_id", "status", "failure_type", "target"],
  "properties": {
    "schema_version": {"const": "ppg-review-finding/v0.1"},
    "finding_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["planned", "candidate", "validated", "committed", "stale", "rejected", "blocked", "owner_gated"]},
    "failure_type": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "summary": {"type": "string"}
  }
}
