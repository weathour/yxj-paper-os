{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ppg-paper-workspace.schema.json",
  "title": "PPG PaperWorkspaceContract",
  "type": "object",
  "required": [
    "schema_version",
    "project_slug",
    "source_root_policy",
    "external_submission_owner_gated",
    "roles",
    "latex_profile",
    "runtime_boundary"
  ],
  "properties": {
    "schema_version": {"const": "ppg-paper-workspace/v0.1"},
    "project_slug": {"type": "string", "minLength": 1},
    "source_root_policy": {"enum": ["single_paper_root_only"]},
    "external_submission_owner_gated": {"const": true},
    "roles": {"type": "object"},
    "latex_profile": {"type": "object"},
    "runtime_boundary": {"type": "object"}
  },
  "additionalProperties": true
}
