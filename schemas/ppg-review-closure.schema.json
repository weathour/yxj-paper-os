{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-review-closure.schema.json",
  "title": "PPG ReviewClosure",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "closure_id", "status", "finding_id", "evidence"],
  "properties": {
    "schema_version": {"const": "ppg-review-closure/v0.1"},
    "closure_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["validated", "committed", "blocked", "rejected"]},
    "finding_id": {"type": "string", "minLength": 1},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
