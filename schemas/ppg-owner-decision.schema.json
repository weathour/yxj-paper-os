{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.yxj/ppg-owner-decision.schema.json",
  "title": "PPG Owner Decision Record",
  "type": "object",
  "required": [
    "schema_version",
    "decision_id",
    "status",
    "question",
    "why_owner_gated",
    "blocks",
    "options",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "ppg-owner-decision/v0.1"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "queued",
        "answered",
        "deferred"
      ]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "why_owner_gated": {
      "type": "string",
      "minLength": 1
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "effect": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "selected_option": {
      "type": ["string", "null"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "answered_at": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
