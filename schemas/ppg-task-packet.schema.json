{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-task-packet.schema.json",
  "title": "PPG TaskPacket",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "packet_id", "status", "mission", "input_materials", "expected_output_schema"],
  "properties": {
    "schema_version": {"const": "ppg-task-packet/v0.1"},
    "packet_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["planned", "candidate", "validated", "committed", "stale", "rejected", "blocked", "owner_gated"]},
    "mission": {"type": "string", "minLength": 1},
    "input_materials": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "expected_output_schema": {"type": "string", "minLength": 1},
    "validators": {"type": "array", "items": {"type": "string"}}
  }
}
