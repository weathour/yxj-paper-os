{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-task-packet.schema.json",
  "title": "PPG TaskPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "status",
    "stage_id",
    "stage_contract_ref",
    "task_kind",
    "agent_type",
    "mission",
    "target_material",
    "input_materials",
    "mandatory_controls",
    "evidence_anchors",
    "forbidden_routes",
    "allowed_actions",
    "allowed_read_paths",
    "allowed_write_paths",
    "allowed_tools",
    "output_artifact_path",
    "expected_output_schema",
    "validators",
    "return_format",
    "ingestion_target",
    "stop_condition",
    "failure_report_format",
    "worker_boot_clause",
    "completion_forbidden",
    "no_recursive_orchestration",
    "owner_gate_required"
  ],
  "properties": {
    "schema_version": {
      "const": "ppg-task-packet/v0.1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "planned"
    },
    "task_kind": {
      "type": "string",
      "minLength": 1
    },
    "agent_type": {
      "type": "string",
      "minLength": 1
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "target_material": {
      "type": "string",
      "minLength": 1
    },
    "input_materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mandatory_controls": {
      "type": "object"
    },
    "evidence_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_routes": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "mark_graph_complete",
          "dispatch_subagents",
          "write_outside_allowed_write_paths",
          "change_owner_intent",
          "alter_unrelated_sections",
          "claim_submission_or_publication_readiness",
          "introduce_new_claims",
          "mark_manuscript_complete",
          "strengthen_claims_beyond_s04"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "mark_graph_complete"
          }
        },
        {
          "contains": {
            "const": "dispatch_subagents"
          }
        },
        {
          "contains": {
            "const": "write_outside_allowed_write_paths"
          }
        },
        {
          "contains": {
            "const": "change_owner_intent"
          }
        }
      ],
      "maxItems": 9,
      "uniqueItems": true
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "read_material_bundle",
          "draft_candidate_artifact",
          "return_evidence"
        ]
      },
      "maxItems": 3,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "read_material_bundle"
          }
        },
        {
          "contains": {
            "const": "draft_candidate_artifact"
          }
        },
        {
          "contains": {
            "const": "return_evidence"
          }
        }
      ]
    },
    "allowed_read_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/materials|examples/review_findings|examples/backflow_tasks)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
      },
      "uniqueItems": true
    },
    "allowed_write_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/candidate-artifacts|examples/materials|runs|figures/src|figures/generated)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
      },
      "maxItems": 8,
      "uniqueItems": true
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "none",
          "python3",
          "Rscript"
        ]
      },
      "maxItems": 1,
      "uniqueItems": true
    },
    "output_artifact_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/candidate-artifacts|examples/materials|runs)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "return_format": {
      "type": "object"
    },
    "ingestion_target": {
      "type": "string",
      "minLength": 1
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    },
    "failure_report_format": {
      "type": "string",
      "minLength": 1
    },
    "worker_boot_clause": {
      "type": "string",
      "minLength": 1
    },
    "completion_forbidden": {
      "const": true
    },
    "no_recursive_orchestration": {
      "const": true
    },
    "owner_gate_required": {
      "const": false
    },
    "stage_id": {
      "type": "string",
      "pattern": "^(S(0[0-8]|09A|09B|1[0-6])|G0[12])$"
    },
    "stage_contract_ref": {
      "type": "string",
      "pattern": "^examples/stage-contracts/(S(0[0-8]|09A|09B|1[0-6])|G0[12])\\.stage-contract\\.json$"
    },
    "expected_material_type": {
      "type": "string",
      "minLength": 1
    },
    "expected_payload_schema": {
      "type": "string",
      "minLength": 1
    },
    "internal_execution_protocol": {
      "type": "object"
    },
    "output_contract": {
      "type": "object"
    },
    "coverage_ledgers_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "descriptive_not_prescriptive_controls": {
      "type": "object"
    },
    "hard_constraints": {
      "type": "object"
    },
    "local_context": {
      "type": "object"
    },
    "adjacent_context": {
      "type": "object"
    },
    "background_context_usage": {
      "type": "object"
    },
    "negative_controls": {
      "type": "object"
    },
    "section_or_unit_move_plan": {
      "type": "object"
    },
    "claim_boundary_controls": {
      "type": "object"
    },
    "object_granularity_controls": {
      "type": "object"
    },
    "terminology_surface_controls": {
      "type": "object"
    },
    "visual_formal_controls": {
      "type": "object"
    },
    "single_writer_lock": {
      "type": "object"
    },
    "packet_authority_boundary": {
      "type": "object"
    },
    "authority_and_target": {
      "type": "object"
    },
    "s08_visual_formal_contract": {
      "type": "object"
    },
    "panel_evidence_package": {
      "type": "array"
    },
    "source_data_package": {
      "type": "object"
    },
    "terminology_and_surface_controls": {
      "type": "object"
    },
    "visual_quality_profile": {
      "type": "object"
    },
    "visual_polish_policy": {
      "type": "object"
    },
    "nature_figure_direct_call": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "enabled",
        "source",
        "adapter_ref",
        "call_step",
        "s11_contract_overrides_skill"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "source": {
          "const": "vendored"
        },
        "adapter_ref": {
          "const": "runtime/adapters/S11NatureFigureDirectCall.adapter.json"
        },
        "call_step": {
          "const": "S11.nature_figure_production_pass"
        },
        "skill_ref": {
          "const": "third_party/nature-figure"
        },
        "parity_manifest_ref": {
          "const": "third_party/nature-figure/PARITY_MANIFEST.json"
        },
        "parity_target": {
          "const": "nature-figure@2.0.0"
        },
        "s11_contract_overrides_skill": {
          "const": true
        },
        "worker_completion_forbidden": {
          "const": true
        },
        "no_recursive_orchestration": {
          "const": true
        }
      }
    },
    "figure_backend": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "selected_backend",
        "selection_source",
        "backend_exclusive",
        "worker_may_ask_backend_question",
        "cross_backend_rendering_forbidden"
      ],
      "properties": {
        "selected_backend": {
          "enum": [
            "python",
            "r"
          ]
        },
        "selection_source": {
          "enum": [
            "S08_backend_route",
            "owner_decision",
            "controller_recommendation_authorized"
          ]
        },
        "backend_exclusive": {
          "const": true
        },
        "worker_may_ask_backend_question": {
          "const": false
        },
        "cross_backend_rendering_forbidden": {
          "const": true
        }
      }
    },
    "render_execution_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mode",
        "missing_runtime_rule",
        "mock_data_forbidden_for_evidential_figures"
      ],
      "properties": {
        "mode": {
          "enum": [
            "render_required",
            "render_allowed",
            "render_plan_allowed"
          ]
        },
        "missing_runtime_rule": {
          "const": "return_missing_material_or_authorized_render_plan_do_not_switch_backend"
        },
        "mock_data_forbidden_for_evidential_figures": {
          "const": true
        }
      }
    },
    "s12_input_package": {
      "type": "object"
    },
    "s10_text_candidates": {
      "type": "array"
    },
    "s11_visual_candidates": {
      "type": "array"
    },
    "upstream_control_materials": {
      "type": "object"
    },
    "stale_material_policy": {
      "type": "object"
    },
    "s13_review_input_package": {
      "type": "object"
    },
    "structured_s12_candidate": {
      "type": "object"
    },
    "reviewer_panel_profile": {
      "type": "array"
    },
    "adversarial_review_protocol": {
      "type": "object"
    },
    "finding_taxonomy": {
      "type": "object"
    },
    "local_backflow_routing_rules": {
      "type": "object"
    },
    "s15_repair_task": {
      "type": "object"
    },
    "repair_scope": {
      "type": "object"
    },
    "pre_repair_snapshot_requirements": {
      "type": "object"
    },
    "affected_downstream_set": {
      "type": "object"
    },
    "protected_unrelated_nodes": {
      "type": "array"
    },
    "diff_locality_requirements": {
      "type": "object"
    },
    "finding_resolution_requirements": {
      "type": "object"
    },
    "regression_scan_requirements": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "stage_id",
          "nature_figure_direct_call",
          "figure_backend"
        ],
        "properties": {
          "stage_id": {
            "const": "S11"
          },
          "nature_figure_direct_call": {
            "type": "object",
            "required": [
              "enabled"
            ],
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "allOf": [
          {
            "properties": {
              "allowed_write_paths": {
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "string",
                  "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/candidate-artifacts|figures/src|figures/generated)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
                }
              },
              "output_artifact_path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)examples/candidate-artifacts/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
              }
            }
          },
          {
            "if": {
              "properties": {
                "figure_backend": {
                  "properties": {
                    "selected_backend": {
                      "const": "python"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "allowed_tools": {
                  "items": {
                    "const": "python3"
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "figure_backend": {
                  "properties": {
                    "selected_backend": {
                      "const": "r"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "allowed_tools": {
                  "items": {
                    "const": "Rscript"
                  }
                }
              }
            }
          }
        ]
      },
      "else": {
        "properties": {
          "allowed_write_paths": {
            "maxItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/candidate-artifacts|examples/materials|runs)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
            }
          },
          "allowed_tools": {
            "items": {
              "const": "none"
            },
            "maxItems": 1
          }
        },
        "not": {
          "anyOf": [
            {
              "required": [
                "nature_figure_direct_call"
              ]
            },
            {
              "required": [
                "figure_backend"
              ]
            },
            {
              "required": [
                "render_execution_policy"
              ]
            }
          ]
        }
      }
    }
  ]
}
