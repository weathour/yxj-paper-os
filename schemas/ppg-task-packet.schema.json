{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yxj.local/schemas/ppg-task-packet.schema.json",
  "title": "PPG TaskPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "status",
    "stage_id",
    "stage_contract_ref",
    "task_kind",
    "agent_type",
    "mission",
    "target_material",
    "input_materials",
    "mandatory_controls",
    "evidence_anchors",
    "forbidden_routes",
    "allowed_actions",
    "allowed_read_paths",
    "allowed_write_paths",
    "allowed_tools",
    "output_artifact_path",
    "expected_output_schema",
    "validators",
    "return_format",
    "ingestion_target",
    "stop_condition",
    "failure_report_format",
    "worker_boot_clause",
    "completion_forbidden",
    "no_recursive_orchestration",
    "owner_gate_required"
  ],
  "properties": {
    "schema_version": {
      "const": "ppg-task-packet/v0.1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "planned"
    },
    "task_kind": {
      "type": "string",
      "minLength": 1
    },
    "agent_type": {
      "type": "string",
      "minLength": 1
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "target_material": {
      "type": "string",
      "minLength": 1
    },
    "input_materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mandatory_controls": {
      "type": "object"
    },
    "evidence_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_routes": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "mark_graph_complete",
          "dispatch_subagents",
          "write_outside_allowed_write_paths",
          "change_owner_intent"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "mark_graph_complete"
          }
        },
        {
          "contains": {
            "const": "dispatch_subagents"
          }
        },
        {
          "contains": {
            "const": "write_outside_allowed_write_paths"
          }
        },
        {
          "contains": {
            "const": "change_owner_intent"
          }
        }
      ],
      "maxItems": 4,
      "uniqueItems": true
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "read_material_bundle",
          "draft_candidate_artifact",
          "return_evidence"
        ]
      },
      "maxItems": 3,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "read_material_bundle"
          }
        },
        {
          "contains": {
            "const": "draft_candidate_artifact"
          }
        },
        {
          "contains": {
            "const": "return_evidence"
          }
        }
      ]
    },
    "allowed_read_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/materials|examples/review_findings|examples/backflow_tasks)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
      },
      "uniqueItems": true
    },
    "allowed_write_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/candidate-artifacts|examples/materials|runs)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
      },
      "maxItems": 1,
      "uniqueItems": true
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "const": "none"
      },
      "maxItems": 1,
      "uniqueItems": true
    },
    "output_artifact_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*(?:^|/)\\.\\.?(?:/|$))(?!~)(?![A-Za-z]:)(examples/candidate-artifacts|examples/materials|runs)/[^\\s\\\\]+\\.[^/\\s\\\\]+$"
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "return_format": {
      "type": "object"
    },
    "ingestion_target": {
      "type": "string",
      "minLength": 1
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    },
    "failure_report_format": {
      "type": "string",
      "minLength": 1
    },
    "worker_boot_clause": {
      "type": "string",
      "minLength": 1
    },
    "completion_forbidden": {
      "const": true
    },
    "no_recursive_orchestration": {
      "const": true
    },
    "owner_gate_required": {
      "const": false
    },
    "stage_id": {
      "type": "string",
      "pattern": "^(S(0[0-8]|09A|09B|1[0-6])|G0[12])$"
    },
    "stage_contract_ref": {
      "type": "string",
      "pattern": "^examples/stage-contracts/(S(0[0-8]|09A|09B|1[0-6])|G0[12])\\.stage-contract\\.json$"
    }
  }
}
