{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ppg-stage-quality-contract.schema.json",
  "title": "PPG StageQualityContract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "stage_id",
    "active_profile_source",
    "must_read_materials",
    "required_extractions",
    "producer_return_obligations",
    "audit_verifier_obligations",
    "downstream_design_force",
    "failure_severity_policy",
    "nearest_responsible_stage_policy",
    "affected_downstream_nodes",
    "anti_over_strictness_boundary"
  ],
  "properties": {
    "schema_version": {"const": "ppg-stage-quality-contract/v0.1"},
    "stage_id": {"type": "string", "pattern": "^(S(0[0-8]|09A|09B|1[0-6])|G0[12])$"},
    "active_profile_source": {"type": "string", "minLength": 1},
    "must_read_materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["material_ref", "read_mode", "required_extractions"],
        "properties": {
          "material_ref": {"type": "string", "minLength": 1},
          "read_mode": {"enum": ["full", "targeted", "locator_only"]},
          "required_extractions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": true
      }
    },
    "required_extractions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "producer_return_obligations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "audit_verifier_obligations": {
      "type": "object",
      "required": ["inherits_all_producer_inputs", "checks"],
      "properties": {
        "inherits_all_producer_inputs": {"const": true},
        "checks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": true
    },
    "downstream_design_force": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "failure_severity_policy": {
      "type": "object",
      "required": ["BLOCKING", "MAJOR", "MINOR", "WATCH"],
      "properties": {
        "BLOCKING": {"type": "string", "minLength": 1},
        "MAJOR": {"type": "string", "minLength": 1},
        "MINOR": {"type": "string", "minLength": 1},
        "WATCH": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "nearest_responsible_stage_policy": {"type": "string", "minLength": 1},
    "affected_downstream_nodes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "anti_over_strictness_boundary": {"type": "string", "minLength": 1}
  }
}
