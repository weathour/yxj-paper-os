{
  "template_count": 70,
  "layers": [
    {
      "id": "L0",
      "title": "L0 Initial human/material roots",
      "intent": "最初输入层：人类立场、选题、基础证据、源材料、模板/资料入口。",
      "materials": [
        "paper-profile.yaml",
        "motivation.yaml",
        "source-map.yaml",
        "citation-bank.yaml",
        "evidence-bank.yaml",
        "template-mirror-policy.yaml",
        "nature-source-inventory.yaml"
      ]
    },
    {
      "id": "L1",
      "title": "L1 Research / template / source understanding",
      "intent": "把原始资料转成可写作的研究场景、读者包、检索策略、模板风格和引用验证。",
      "materials": [
        "research-dossier.yaml",
        "paper-reader-package.yaml",
        "search-strategy-dossier.yaml",
        "template-quant-profile.yaml",
        "journal-style-profile.yaml",
        "citation-verification-report.yaml"
      ]
    },
    {
      "id": "L2",
      "title": "L2 Evidence / claim / admissibility control",
      "intent": "把证据、引用和实验结果转成 claim 边界与可见性控制。",
      "materials": [
        "claim-citation-capsule.yaml",
        "result-package.yaml",
        "claim-evidence-visibility-map.yaml",
        "data-availability-plan.yaml"
      ]
    },
    {
      "id": "L3",
      "title": "L3 Reader narrative / expression design",
      "intent": "形成读者问题、对象表示、章节功能、认知负荷、解释阶梯、修辞动作和术语控制。",
      "materials": [
        "reader-spine-brief.yaml",
        "reviewer-question-map.yaml",
        "object-representation-matrix.yaml",
        "main-text-construction-matrix.yaml",
        "section-function-budget.yaml",
        "visual-table-algorithm-formula-budget.yaml",
        "cognitive-load-budget.yaml",
        "explanation-ladder.yaml",
        "rhetorical-move-matrix.yaml",
        "terminology-register.yaml",
        "expression-design-bundle.yaml",
        "main-text-surface-rules.yaml",
        "rationale-matrix.yaml"
      ]
    },
    {
      "id": "L4A",
      "title": "L4A Main-text production planning",
      "intent": "把控制物料编译成具体章节/段落移动、写作任务和可执行边界。",
      "materials": [
        "task-packet.yaml",
        "section-move-plan.yaml",
        "single-writer-section-lock.yaml"
      ]
    },
    {
      "id": "L4B",
      "title": "L4B Figure / visual / formal production",
      "intent": "把图表、算法、公式和 caption 作为证据承载物进行设计、绘制、导出。",
      "materials": [
        "nature-figure-contract.yaml",
        "nature-figure-aesthetic-profile.yaml",
        "nature-panel-evidence-map.yaml",
        "figure-backend-route.yaml",
        "figure-source-data-statistics.yaml",
        "figure-image-integrity-record.yaml",
        "nature-caption-legend-brief.yaml",
        "figure-export-bundle.yaml"
      ]
    },
    {
      "id": "L5",
      "title": "L5 Manuscript review / loss signals",
      "intent": "对正文、读者体验、图表、渲染和验证结果产生 loss/finding。",
      "materials": [
        "reviewer-panel-report.yaml",
        "review-output.yaml",
        "reader-experience-review-report.yaml",
        "reader-surface-tutor-review.yaml",
        "rendered-surface-gate-report.yaml",
        "nature-figure-qa-report.yaml",
        "validator-report.yaml"
      ]
    },
    {
      "id": "L6",
      "title": "L6 Backflow / repair / revision outputs",
      "intent": "把审核结果转成 narrative 回流、polishing 修复、response/rebuttal 映射。",
      "materials": [
        "narrative-backflow-task.yaml",
        "polishing-repair-report.yaml",
        "response-action-map.yaml"
      ]
    },
    {
      "id": "L7",
      "title": "L7 Export / handoff / delivery readiness",
      "intent": "把成品论文、图表、仓库和导出包变成可交付状态。",
      "materials": [
        "export-manifest.yaml",
        "repository-hygiene-report.yaml",
        "manager-handoff-report.md",
        "manager-handoff-report-v2.md"
      ]
    },
    {
      "id": "S1",
      "title": "Sidecar A Runtime governance, not forward-writing cognition",
      "intent": "不属于论文语义 forward pass，但用于 PMO、部门、权限、状态和任务治理。",
      "materials": [
        "state.yaml",
        "manager-boot-checklist.yaml",
        "manager-direct-intervention.yaml",
        "department-charter.yaml",
        "department-io-contract.yaml",
        "department-lane-registry.yaml",
        "department-material-manifest.yaml",
        "department-route-card.yaml",
        "department-state.yaml",
        "department-handoff-report.yaml",
        "required-function-material-map.yaml",
        "company-skill-registry.yaml"
      ]
    },
    {
      "id": "S2",
      "title": "Sidecar B Post-paper / external derivative / plugin absorption",
      "intent": "不在主干论文成文路径中；用于演示、专利边界、Nature 能力吸收闭包等后续或外部用途。",
      "materials": [
        "presentation-plan.yaml",
        "patent-draft-boundary.yaml",
        "nature-absorption-package.yaml"
      ]
    }
  ]
}
