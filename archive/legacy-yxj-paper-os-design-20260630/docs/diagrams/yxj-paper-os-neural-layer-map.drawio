<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="yxj-paper-os neural layer map">
    <mxGraphModel dx="2200" dy="2000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="yxj-paper-os materials reorganized as neural-network layers&#xa;Main flow uses paper-analysis/production materials; sidecar holds non-forward-pass governance/post-paper materials" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="300" y="20" width="1200" height="70" as="geometry" /></mxCell>
        <mxCell id="3" value="L0  L0 Initial human/material roots&#xa;最初输入层：人类立场、选题、基础证据、源材料、模板/资料入口。&#xa;&#xa;• paper-profile.yaml&#xa;• motivation.yaml&#xa;• source-map.yaml&#xa;• citation-bank.yaml&#xa;• evidence-bank.yaml&#xa;• template-mirror-policy.yaml&#xa;• nature-source-inventory.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="130" width="1360" height="210" as="geometry" /></mxCell>
        <mxCell id="4" value="L1  L1 Research / template / source understanding&#xa;把原始资料转成可写作的研究场景、读者包、检索策略、模板风格和引用验证。&#xa;&#xa;• research-dossier.yaml&#xa;• paper-reader-package.yaml&#xa;• search-strategy-dossier.yaml&#xa;• template-quant-profile.yaml&#xa;• journal-style-profile.yaml&#xa;• citation-verification-report.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="385" width="1360" height="192" as="geometry" /></mxCell>
        <mxCell id="5" value="L2  L2 Evidence / claim / admissibility control&#xa;把证据、引用和实验结果转成 claim 边界与可见性控制。&#xa;&#xa;• claim-citation-capsule.yaml&#xa;• result-package.yaml&#xa;• claim-evidence-visibility-map.yaml&#xa;• data-availability-plan.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="622" width="1360" height="156" as="geometry" /></mxCell>
        <mxCell id="6" value="L3  L3 Reader narrative / expression design&#xa;形成读者问题、对象表示、章节功能、认知负荷、解释阶梯、修辞动作和术语控制。&#xa;&#xa;• reader-spine-brief.yaml&#xa;• reviewer-question-map.yaml&#xa;• object-representation-matrix.yaml&#xa;• main-text-construction-matrix.yaml&#xa;• section-function-budget.yaml&#xa;• visual-table-algorithm-formula-budget.yaml&#xa;• cognitive-load-budget.yaml&#xa;• explanation-ladder.yaml&#xa;• rhetorical-move-matrix.yaml&#xa;• terminology-register.yaml&#xa;• expression-design-bundle.yaml&#xa;• main-text-surface-rules.yaml&#xa;• rationale-matrix.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="823" width="1360" height="318" as="geometry" /></mxCell>
        <mxCell id="7" value="L4A  L4A Main-text production planning&#xa;把控制物料编译成具体章节/段落移动、写作任务和可执行边界。&#xa;&#xa;• task-packet.yaml&#xa;• section-move-plan.yaml&#xa;• single-writer-section-lock.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="1186" width="1360" height="138" as="geometry" /></mxCell>
        <mxCell id="8" value="L4B  L4B Figure / visual / formal production&#xa;把图表、算法、公式和 caption 作为证据承载物进行设计、绘制、导出。&#xa;&#xa;• nature-figure-contract.yaml&#xa;• nature-figure-aesthetic-profile.yaml&#xa;• nature-panel-evidence-map.yaml&#xa;• figure-backend-route.yaml&#xa;• figure-source-data-statistics.yaml&#xa;• figure-image-integrity-record.yaml&#xa;• nature-caption-legend-brief.yaml&#xa;• figure-export-bundle.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="1369" width="1360" height="228" as="geometry" /></mxCell>
        <mxCell id="9" value="L5  L5 Manuscript review / loss signals&#xa;对正文、读者体验、图表、渲染和验证结果产生 loss/finding。&#xa;&#xa;• reviewer-panel-report.yaml&#xa;• review-output.yaml&#xa;• reader-experience-review-report.yaml&#xa;• reader-surface-tutor-review.yaml&#xa;• rendered-surface-gate-report.yaml&#xa;• nature-figure-qa-report.yaml&#xa;• validator-report.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="1642" width="1360" height="210" as="geometry" /></mxCell>
        <mxCell id="10" value="L6  L6 Backflow / repair / revision outputs&#xa;把审核结果转成 narrative 回流、polishing 修复、response/rebuttal 映射。&#xa;&#xa;• narrative-backflow-task.yaml&#xa;• polishing-repair-report.yaml&#xa;• response-action-map.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="1897" width="1360" height="138" as="geometry" /></mxCell>
        <mxCell id="11" value="L7  L7 Export / handoff / delivery readiness&#xa;把成品论文、图表、仓库和导出包变成可交付状态。&#xa;&#xa;• export-manifest.yaml&#xa;• repository-hygiene-report.yaml&#xa;• manager-handoff-report.md&#xa;• manager-handoff-report-v2.md" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="120" y="2080" width="1360" height="156" as="geometry" /></mxCell>
        <mxCell id="12" value="S1  Sidecar A Runtime governance, not forward-writing cognition&#xa;不属于论文语义 forward pass，但用于 PMO、部门、权限、状态和任务治理。&#xa;&#xa;• state.yaml&#xa;• manager-boot-checklist.yaml&#xa;• manager-direct-intervention.yaml&#xa;• department-charter.yaml&#xa;• department-io-contract.yaml&#xa;• department-lane-registry.yaml&#xa;• department-material-manifest.yaml&#xa;• department-route-card.yaml&#xa;• department-state.yaml&#xa;• department-handoff-report.yaml&#xa;• required-function-material-map.yaml&#xa;• company-skill-registry.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;strokeWidth=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="1560" y="280" width="520" height="308" as="geometry" /></mxCell>
        <mxCell id="13" value="S2  Sidecar B Post-paper / external derivative / plugin absorption&#xa;不在主干论文成文路径中；用于演示、专利边界、Nature 能力吸收闭包等后续或外部用途。&#xa;&#xa;• presentation-plan.yaml&#xa;• patent-draft-boundary.yaml&#xa;• nature-absorption-package.yaml" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;strokeWidth=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="1560" y="668" width="520" height="150" as="geometry" /></mxCell>
